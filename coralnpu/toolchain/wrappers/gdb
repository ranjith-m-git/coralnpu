PROG=$(basename "$0")
DRIVER_DIR=$(dirname "$0")
PREFIX="riscv32-unknown-elf"

# Locate the riscv toolchain repo. When invoked from a bazel test's runfiles
# tree, the toolchain lives at runfiles/+hw_deps+toolchain_coralnpu_v2/. When
# invoked from execroot during a build action it's at external/<canonical>/.
# The wrapper file itself is at <root>/toolchain/wrappers/gdb (or a symlink
# into _main/toolchain/wrappers/gdb under runfiles), so search siblings.
_find_toolchain_bin() {
    local d="$1"
    while [[ "$d" != "/" && "$d" != "" ]]; do
        local match
        match=$(ls -d "${d}/external/"*toolchain_coralnpu_v2 2>/dev/null | head -1)
        if [[ -z "${match}" ]]; then
            match=$(ls -d "${d}/"*toolchain_coralnpu_v2 2>/dev/null | head -1)
        fi
        if [[ -n "${match}" && -x "${match}/bin/${PREFIX}-gdb" ]]; then
            echo "${match}/bin/${PREFIX}-gdb"
            return
        fi
        d=$(dirname "$d")
    done
}

GDB=$(_find_toolchain_bin "${DRIVER_DIR}")
if [[ -z "${GDB}" ]]; then
    echo "$0: cannot locate ${PREFIX}-gdb under any external/*toolchain_coralnpu_v2" 1>&2
    exit 1
fi

LIBMPFR_PATH=$(ldconfig -p | grep 'mpfr.so$' | awk '{print $4}')
WORKDIR=$(mktemp -d)
trap "rm -rf ${WORKDIR}" EXIT
[[ -n "${LIBMPFR_PATH}" ]] && ln -sf "${LIBMPFR_PATH}" "${WORKDIR}/libmpfr.so.4"

export LD_LIBRARY_PATH="${WORKDIR}:${LD_LIBRARY_PATH}"
exec "${GDB}" "$@"
